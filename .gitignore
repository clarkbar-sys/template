# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.code-workspace

# ── Logs & temp ───────────────────────────────────────────────
*.log
tmp/
.cache/

# ── Secrets & local env (never commit these) ─────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── s7 Scheme ─────────────────────────────────────────────────
# Fetched s7 source (downloaded by scripts/fetch-s7.sh)
/.s7/
/bin/
out/
*.o
# Generated when the REPL builds its FFI shim locally
lib*_s7.c
lib*_s7.so

# ── Language-specific: uncomment the section for your stack ───
#
# Node:
# node_modules/
# dist/
# coverage/
# *.tsbuildinfo
#
# Python:
# __pycache__/
# *.py[cod]
# .venv/
# .pytest_cache/
# .ruff_cache/
# build/
# *.egg-info/
#
# Go:
# /bin/
# *.test
# *.out
