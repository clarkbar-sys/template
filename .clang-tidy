# Static analysis for C/C++. Runs in CI once a compile_commands.json exists
# (i.e. once you have a real cmake/meson build) — see the note in ci-c.yml.
#
# Philosophy: turn on the high-signal families (bugprone, correctness, security,
# performance, portability) and disable the noisy/opinionated checks that fight a
# small template. Trim or extend per project.
---
Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-braces-around-statements,
  -misc-no-recursion,
  -misc-include-cleaner,
  -bugprone-easily-swappable-parameters,
  -cert-err58-cpp

# Treat nothing as a hard error by default so the check set can evolve; flip
# specific critical checks (or all) into WarningsAsErrors once the baseline is
# clean and you want them to gate.
WarningsAsErrors: ''

HeaderFilterRegex: '.*'
FormatStyle: file

CheckOptions:
  - key: readability-identifier-naming.FunctionCase
    value: lower_case
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key: readability-identifier-naming.StructCase
    value: lower_case
  - key: readability-identifier-naming.EnumCase
    value: lower_case
